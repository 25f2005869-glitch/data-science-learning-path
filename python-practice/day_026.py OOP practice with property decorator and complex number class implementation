class complex:
    def __init__(self, real, img):
        self.real = real
        self.img = img

    def showNumber(self):
        print(self.real,"i +", self.img,"j")

    def add(self, num2):
        newReal = self.real + num2.real
        newImg = self.img + num2.img
        return complex(newReal, newImg)

num1 = complex(1, 3)
num1.showwNumber()

num2 = complex(4, 9)
num2.showwNumber()

num3 = num1.add(num2)
num3.showwNumber()

